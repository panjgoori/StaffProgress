<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cloud Staff Performance Tracker</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
</head>
<body class="bg-gray-50 font-sans text-gray-800">

    <div id="loading-overlay" class="fixed inset-0 bg-gray-900/50 backdrop-blur-xs flex items-center justify-center z-50 transition-opacity duration-200">
        <div class="bg-white p-6 rounded-lg shadow-xl flex items-center space-x-4">
            <div class="animate-spin rounded-full h-8 w-8 border-4 border-indigo-600 border-t-transparent"></div>
            <p class="font-medium text-gray-700" id="loading-text">Syncing with Google Sheets...</p>
        </div>
    </div>

    <div class="max-w-6xl mx-auto p-4 sm:p-6 lg:p-8">
        <header class="mb-8 flex flex-col sm:flex-row justify-between items-center gap-4 bg-white p-6 rounded-lg shadow-sm border border-gray-100">
            <div class="text-center sm:text-left">
                <h1 class="text-2xl font-bold text-gray-900">Staff Performance Tracker</h1>
                <p class="text-gray-500 text-sm flex items-center justify-center sm:justify-start gap-2">
                    <span>Cloud Sync Enabled</span>
                    <span id="admin-badge" class="hidden bg-red-100 text-red-800 text-xs font-bold px-2 py-0.5 rounded-full">Admin Mode</span>
                    <span id="readonly-badge" class="bg-gray-100 text-gray-800 text-xs font-bold px-2 py-0.5 rounded-full">Read-Only</span>
                </p>
            </div>
            <div class="flex flex-wrap gap-2 justify-center">
                <button onclick="fetchFromCloud()" class="bg-gray-600 hover:bg-gray-700 text-white text-xs font-semibold py-2 px-3 rounded shadow-sm transition">
                    🔄 Refresh Data
                </button>
                <button onclick="exportToExcel()" class="bg-green-600 hover:bg-green-700 text-white text-xs font-semibold py-2 px-3 rounded shadow-sm transition">
                    📊 Export Excel
                </button>
            </div>
        </header>

        <div class="flex flex-wrap border-b border-gray-200 mb-6 bg-white rounded-t-lg shadow-sm">
            <button onclick="switchTab('log-tab')" id="btn-log-tab" class="tab-btn flex-1 min-w-[120px] py-4 px-2 text-center font-medium text-sm border-b-2 border-indigo-600 text-indigo-600 focus:outline-none">
                Log Data
            </button>
            <button onclick="switchTab('progress-tab')" id="btn-progress-tab" class="tab-btn flex-1 min-w-[120px] py-4 px-2 text-center font-medium text-sm border-b-2 border-transparent text-gray-500 hover:text-gray-700 focus:outline-none">
                Weekly Progress
            </button>
            <button onclick="switchTab('compare-tab')" id="btn-compare-tab" class="tab-btn flex-1 min-w-[120px] py-4 px-2 text-center font-medium text-sm border-b-2 border-transparent text-gray-500 hover:text-gray-700 focus:outline-none">
                Comparison
            </button>
            <button onclick="switchTab('manage-tab')" id="btn-manage-tab" class="admin-only hidden flex-1 min-w-[120px] py-4 px-2 text-center font-medium text-sm border-b-2 border-transparent text-gray-500 hover:text-gray-700 focus:outline-none">
                ⚙️ Manage Staff
            </button>
        </div>

        <div id="log-tab" class="tab-content block">
            <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
                <div class="flex justify-between items-center mb-4">
                    <h2 id="log-tab-title" class="text-xl font-semibold text-gray-900">Daily Metrics</h2>
                    <div>
                        <select id="selected-day" class="p-2 border border-gray-300 rounded-md bg-white focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-medium text-sm" required>
                            <option value="Monday">Monday</option>
                            <option value="Tuesday">Tuesday</option>
                            <option value="Wednesday">Wednesday</option>
                            <option value="Thursday">Thursday</option>
                            <option value="Friday">Friday</option>
                        </select>
                    </div>
                </div>

                <form id="data-form" onsubmit="saveData(event)" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="staff-inputs-container">
                        </div>
                    <div id="no-staff-warning" class="hidden text-center py-6 text-gray-500 italic">
                        No staff profiles created yet.
                    </div>
                    <div id="save-btn-container" class="admin-only hidden flex justify-end border-t border-gray-100 pt-4">
                        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 px-6 rounded-md shadow-sm transition-colors">
                            Save Day's Data
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div id="progress-tab" class="tab-content hidden">
            <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
                <h2 class="text-xl font-semibold mb-4 text-gray-900">Weekly Progress Overview</h2>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="p-4 font-semibold text-gray-900">Staff Member</th>
                                <th class="p-4 font-semibold text-gray-900">Mon</th>
                                <th class="p-4 font-semibold text-gray-900">Tue</th>
                                <th class="p-4 font-semibold text-gray-900">Wed</th>
                                <th class="p-4 font-semibold text-gray-900">Thu</th>
                                <th class="p-4 font-semibold text-gray-900">Fri</th>
                                <th class="p-4 font-semibold text-gray-900 bg-indigo-50 text-indigo-900">Total</th>
                            </tr>
                        </thead>
                        <tbody id="progress-table-body" class="divide-y divide-gray-200">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="compare-tab" class="tab-content hidden">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 bg-white p-6 rounded-lg shadow-sm border border-gray-100">
                    <h2 class="text-xl font-semibold mb-4 text-gray-900">Performance Breakdown</h2>
                    <div class="relative min-h-[350px]">
                        <canvas id="comparisonChart"></canvas>
                    </div>
                </div>
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
                    <h2 class="text-xl font-semibold mb-4 text-gray-900">Leaderboard</h2>
                    <ol id="leaderboard-list" class="space-y-3 divide-y divide-gray-100">
                        </ol>
                </div>
            </div>
        </div>

        <div id="manage-tab" class="tab-content hidden">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 h-fit">
                    <h2 class="text-xl font-semibold mb-4 text-gray-900">Add Staff Profile</h2>
                    <form onsubmit="addStaffMember(event)" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                            <input type="text" id="new-staff-name" placeholder="e.g., John Doe" class="w-full p-2 border border-gray-300 rounded focus:ring-2 focus:ring-indigo-500 focus:outline-none" required>
                        </div>
                        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 rounded shadow transition">
                            Add Member
                        </button>
                    </form>
                </div>
                <div class="md:col-span-2 bg-white p-6 rounded-lg shadow-sm border border-gray-100">
                    <h2 class="text-xl font-semibold mb-4 text-gray-900">Current Directory</h2>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="p-4 font-semibold text-gray-900">Name</th>
                                    <th class="p-4 font-semibold text-right text-gray-900">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="management-table-body" class="divide-y divide-gray-200">
                                </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // PASTE YOUR GOOGLE WEB APP URL HERE
        const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbw_Weo34Z0aXfsl85TwjzBgfah2FatoJRj5LLQjEob3RYQ6Nkk_uvgk9el334HwZBn9WQ/exec";

        const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];
        let staffList = [];
        let performanceData = { "Monday": {}, "Tuesday": {}, "Wednesday": {}, "Thursday": {}, "Friday": {} };
        let chartInstance = null;
        
        // Global Access Control Flag
        let isAdmin = false;

        // Check URL Parameters for Admin Status
        function checkAdminStatus() {
            const urlParams = new URLSearchParams(window.location.search);
            isAdmin = urlParams.get('admin') === 'true';

            if (isAdmin) {
                // Reveal Admin features
                document.querySelectorAll('.admin-only').forEach(el => el.classList.remove('hidden'));
                document.getElementById('admin-badge').classList.remove('hidden');
                document.getElementById('readonly-badge').classList.add('hidden');
                document.getElementById('log-tab-title').innerText = "Enter Daily Metrics";
            } else {
                document.getElementById('log-tab-title').innerText = "Daily Metrics View";
            }
        }

        function showLoading(text) {
            document.getElementById('loading-text').innerText = text;
            document.getElementById('loading-overlay').style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loading-overlay').style.display = 'none';
        }

        async function fetchFromCloud() {
            if (SCRIPT_URL.includes("YOUR_GOOGLE_SCRIPT_WEB_APP_URL_HERE")) {
                hideLoading();
                alert("Please add your Google Apps Script Web App URL to the code first!");
                return;
            }
            showLoading("Fetching latest metrics from Google Sheets...");
            try {
                const response = await fetch(SCRIPT_URL);
                const cloudData = await response.json();
                
                staffList = cloudData.staffList || [];
                performanceData = cloudData.performanceData || { "Monday": {}, "Tuesday": {}, "Wednesday": {}, "Thursday": {}, "Friday": {} };
                
                sanitizeDataState();
                initInputForm();
                refreshViews();
                if (isAdmin) renderManagementDirectory();
            } catch (error) {
                console.error("Error reading from cloud DB:", error);
                alert("Failed to connect to cloud database.");
            } finally {
                hideLoading();
            }
        }

        async function pushToCloud() {
            if (!isAdmin) return;
            showLoading("Saving data to Google Sheets Cloud...");
            const dataPayload = { staffList: staffList, performanceData: performanceData };
            try {
                await fetch(SCRIPT_URL, {
                    method: 'POST',
                    mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dataPayload)
                });
                alert("Cloud database successfully updated!");
            } catch (error) {
                console.error("Error saving to cloud DB:", error);
                alert("Cloud update execution failed.");
            } finally {
                hideLoading();
                refreshViews();
            }
        }

        function sanitizeDataState() {
            days.forEach(day => {
                if (!performanceData[day]) performanceData[day] = {};
                staffList.forEach(staff => {
                    if (performanceData[day][staff] === undefined) performanceData[day][staff] = 0; 
                });
            });
        }

        function initInputForm() {
            const container = document.getElementById('staff-inputs-container');
            const warning = document.getElementById('no-staff-warning');
            container.innerHTML = '';
            
            if (staffList.length === 0) {
                warning.classList.remove('hidden');
                return;
            }
            warning.classList.add('hidden');

            staffList.forEach(staff => {
                const div = document.createElement('div');
                div.className = 'bg-gray-50 p-4 rounded-md border border-gray-200';
                
                if (isAdmin) {
                    // Admin View: Input fields
                    div.innerHTML = `
                        <label class="block text-sm font-semibold text-gray-700 mb-1 truncate" title="${staff}">${staff}</label>
                        <input type="number" data-staff="${staff}" min="0" step="any" class="staff-score-input w-full p-2 border border-gray-300 rounded bg-white focus:ring-2 focus:ring-indigo-500 focus:outline-none" placeholder="0">
                    `;
                } else {
                    // Public View: Clean stylized plain text badges
                    div.innerHTML = `
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 truncate" title="${staff}">${staff}</label>
                        <div id="view-${staff.replace(/\s+/g, '-')}" class="text-xl font-bold text-indigo-700 bg-indigo-50/50 p-2 rounded border border-indigo-100">-</div>
                    `;
                }
                container.appendChild(div);
            });
            updateFormInputsForDay();
        }

        document.getElementById('selected-day').addEventListener('change', updateFormInputsForDay);

        function updateFormInputsForDay() {
            const currentDay = document.getElementById('selected-day').value;
            
            if (isAdmin) {
                const inputs = document.querySelectorAll('.staff-score-input');
                inputs.forEach(input => {
                    const staffName = input.getAttribute('data-staff');
                    input.value = (performanceData[currentDay] && performanceData[currentDay][staffName] !== undefined) ? performanceData[currentDay][staffName] : '';
                });
            } else {
                staffList.forEach(staff => {
                    const displayEl = document.getElementById(`view-${staff.replace(/\s+/g, '-')}`);
                    if (displayEl) {
                        const val = (performanceData[currentDay] && performanceData[currentDay][staff] !== undefined) ? performanceData[currentDay][staff] : 0;
                        displayEl.innerText = val;
                    }
                });
            }
        }

        function saveData(e) {
            e.preventDefault();
            if (!isAdmin) return;
            const selectedDay = document.getElementById('selected-day').value;
            const inputs = document.querySelectorAll('.staff-score-input');
            
            inputs.forEach(input => {
                const staffName = input.getAttribute('data-staff');
                const val = parseFloat(input.value);
                performanceData[selectedDay][staffName] = isNaN(val) ? 0 : val;
            });
            pushToCloud();
        }

        function renderProgressTable() {
            const tbody = document.getElementById('progress-table-body');
            tbody.innerHTML = '';

            if (staffList.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="p-4 text-center text-gray-500 italic">No staff found.</td></tr>`;
                return;
            }

            staffList.forEach(staff => {
                let rowTotal = 0;
                let cellsHtml = days.map(day => {
                    const val = (performanceData[day] && performanceData[day][staff]) ? performanceData[day][staff] : 0;
                    rowTotal += val;
                    return `<td class="p-4 text-gray-600">${val}</td>`;
                }).join('');

                const row = document.createElement('tr');
                row.className = 'hover:bg-gray-50 transition-colors';
                row.innerHTML = `
                    <td class="p-4 font-medium text-gray-900 max-w-[180px] truncate" title="${staff}">${staff}</td>
                    ${cellsHtml}
                    <td class="p-4 font-bold bg-indigo-50/50 text-indigo-700">${rowTotal}</td>
                `;
                tbody.appendChild(row);
            });
        }

        function renderLeaderboardAndChart() {
            const staffTotals = staffList.map(staff => {
                const total = days.reduce((sum, day) => sum + ((performanceData[day] && performanceData[day][staff]) ? performanceData[day][staff] : 0), 0);
                return { name: staff, total: total };
            });

            const sortedStaff = [...staffTotals].sort((a, b) => b.total - a.total);
            const leaderboard = document.getElementById('leaderboard-list');
            leaderboard.innerHTML = '';
            
            if (sortedStaff.length === 0) {
                leaderboard.innerHTML = `<li class="text-gray-500 text-sm italic py-2">No standings available.</li>`;
            }

            sortedStaff.forEach((staff, index) => {
                const li = document.createElement('li');
                li.className = 'flex justify-between items-center py-3 first:pt-0';
                li.innerHTML = `
                    <div class="flex items-center space-x-3 min-w-0">
                        <span class="flex items-center justify-center shrink-0 w-6 h-6 rounded-full text-xs font-bold ${index === 0 ? 'bg-amber-100 text-amber-800' : 'bg-gray-100 text-gray-700'}">${index + 1}</span>
                        <span class="font-medium text-gray-800 truncate" title="${staff.name}">${staff.name}</span>
                    </div>
                    <span class="font-bold text-gray-900 shrink-0 ml-2">${staff.total} pts</span>
                `;
                leaderboard.appendChild(li);
            });

            const ctx = document.getElementById('comparisonChart').getContext('2d');
            if (chartInstance) chartInstance.destroy();

            const datasets = staffList.map((staff, idx) => {
                const colors = ['#4f46e5', '#0d9488', '#d97706', '#dc2626', '#9333ea', '#4b5563', '#ec4899'];
                return {
                    label: staff,
                    data: days.map(day => (performanceData[day] && performanceData[day][staff]) ? performanceData[day][staff] : 0),
                    backgroundColor: colors[idx % colors.length],
                    borderRadius: 4
                };
            });

            chartInstance = new Chart(ctx, {
                type: 'bar',
                data: { labels: days, datasets: datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, grid: { color: '#f3f4f6' } }, x: { grid: { display: false } } },
                    plugins: { legend: { position: 'top', labels: { boxWidth: 10, usePointStyle: true } } }
                }
            });
        }

        function renderManagementDirectory() {
            const tbody = document.getElementById('management-table-body');
            tbody.innerHTML = '';

            if(staffList.length === 0) {
                tbody.innerHTML = `<tr><td colspan="2" class="p-4 text-center text-gray-500 italic">No staff profiles registered.</td></tr>`;
                return;
            }

            staffList.forEach(staff => {
                const row = document.createElement('tr');
                row.className = 'hover:bg-gray-50';
                row.innerHTML = `
                    <td class="p-4 font-medium text-gray-800">${staff}</td>
                    <td class="p-4 text-right">
                        <button onclick="deleteStaffMember('${staff.replace(/'/g, "\\'")}')" class="text-red-600 hover:text-red-900 font-semibold text-xs py-1 px-2.5 rounded hover:bg-red-50 transition">
                            Delete Profile
                        </button>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        function addStaffMember(e) {
            e.preventDefault();
            if (!isAdmin) return;
            const input = document.getElementById('new-staff-name');
            const name = input.value.trim();

            if (!name || staffList.includes(name)) return;

            staffList.push(name);
            sanitizeDataState();
            input.value = '';
            
            renderManagementDirectory();
            initInputForm();
            pushToCloud();
        }

        function deleteStaffMember(name) {
            if (!isAdmin) return;
            if (!confirm(`Are you sure you want to delete "${name}"?`)) return;

            staffList = staffList.filter(item => item !== name);
            days.forEach(day => { if (performanceData[day][name] !== undefined) delete performanceData[day][name]; });

            renderManagementDirectory();
            initInputForm();
            pushToCloud();
        }

        function exportToExcel() {
            if(staffList.length === 0) return;
            const rows = staffList.map(staff => {
                return {
                    "Staff Name": staff,
                    "Monday": performanceData["Monday"][staff] || 0,
                    "Tuesday": performanceData["Tuesday"][staff] || 0,
                    "Wednesday": performanceData["Wednesday"][staff] || 0,
                    "Thursday": performanceData["Thursday"][staff] || 0,
                    "Friday": performanceData["Friday"][staff] || 0
                };
            });
            const worksheet = XLSX.utils.json_to_sheet(rows);
            const workbook = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(workbook, worksheet, "Performance");
            XLSX.writeFile(workbook, `Performance_Cloud_Export.xlsx`);
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.replace('block', 'hidden'));
            document.getElementById(tabId).classList.replace('hidden', 'block');
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('border-indigo-600', 'text-indigo-600');
                btn.classList.add('border-transparent', 'text-gray-500');
            });
            document.getElementById(`btn-${tabId}`).classList.add('border-indigo-600', 'text-indigo-600');
            if(tabId !== 'manage-tab') refreshViews();
        }

        function refreshViews() {
            renderProgressTable();
            renderLeaderboardAndChart();
        }

        window.onload = function() {
            checkAdminStatus();
            fetchFromCloud();
        };
    </script>
</body>
</html>
